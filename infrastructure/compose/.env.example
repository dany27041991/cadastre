# =============================================================================
# Catasto Arboreo Comunale - Environment Variables
# =============================================================================
# Copia questo file in .env e modifica i valori per il tuo ambiente.
# Per produzione: genera secret robusti (openssl rand -hex 32)
# =============================================================================

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
APP_ENV=development
APP_TIMEZONE=Europe/Rome

# -----------------------------------------------------------------------------
# PostgreSQL + PostGIS
# -----------------------------------------------------------------------------
POSTGRES_DB=arboreal_green_cadastre
POSTGRES_USER=cadastre
# Generate a secure password: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32
POSTGRES_PORT=5432
# Host: localhost for backend run outside Docker; compose passes POSTGRES_HOST=postgis to backend
POSTGRES_HOST=localhost

# -----------------------------------------------------------------------------
# PgBouncer (usa stesse credenziali Postgres)
# -----------------------------------------------------------------------------
# Configurato automaticamente via DATABASE_URL nel compose

# -----------------------------------------------------------------------------
# Backend API (FastAPI)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
BACKEND_PORT=8000
# Admin areas cache TTL (regions, provinces, municipalities, sub-municipal); default 24h
ADMIN_AREAS_CACHE_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# Frontend (React + Vite + OpenLayers)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=5173

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Nessuna configurazione aggiuntiva (default: no auth in dev)

# -----------------------------------------------------------------------------
# ClickHouse - OLAP Analytics
# -----------------------------------------------------------------------------
CLICKHOUSE_DB=cadastre_analytics
CLICKHOUSE_USER=cadastre
# Generate: openssl rand -hex 24
CLICKHOUSE_PASSWORD=CHANGE_ME_use_openssl_rand_hex_24
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# -----------------------------------------------------------------------------
# PgAdmin (opzionale - profile: tools)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@cadastre.local
PGADMIN_PASSWORD=CHANGE_ME_admin_password
PGADMIN_PORT=5050
