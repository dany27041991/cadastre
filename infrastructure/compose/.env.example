# =============================================================================
# Catasto Arboreo Comunale - Environment Variables
# =============================================================================
# Copia questo file in .env e modifica i valori per il tuo ambiente.
# Per produzione: genera secret robusti (openssl rand -hex 32)
# =============================================================================

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
APP_ENV=development
APP_TIMEZONE=Europe/Rome

# -----------------------------------------------------------------------------
# PostgreSQL + PostGIS
# -----------------------------------------------------------------------------
POSTGRES_DB=arboreal_green_cadastre
POSTGRES_USER=cadastre
# Generate a secure password: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32
POSTGRES_PORT=5432
# Host: localhost for backend run outside Docker; compose passes POSTGRES_HOST=postgis to backend
POSTGRES_HOST=localhost

# -----------------------------------------------------------------------------
# PgBouncer (usa stesse credenziali Postgres)
# -----------------------------------------------------------------------------
# Configurato automaticamente via DATABASE_URL nel compose

# -----------------------------------------------------------------------------
# Backend API (FastAPI)
# -----------------------------------------------------------------------------
# Generate a secret: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,https://sim-dev.mase.gov.it
BACKEND_PORT=8000
BACKEND_DEBUG_PORT=5678
# Debug: attach IDE al backend (porta 5678). Per disattivare: commenta DEBUGPY_ENABLE.
DEBUGPY_ENABLE=1
# Logging: livello root e uvicorn (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Admin areas cache TTL (regions, provinces, municipalities, sub-municipal); default 24h
ADMIN_AREAS_CACHE_TTL_SECONDS=86400

# Build backend/init (Docker): necessario per pip install mase-utils-secu da Nexus (verifica token JWT/FGP).
PIP_EXTRA_INDEX_URL=https://nexus3-cdp.apps.dxccdp-svil.ocp.mase.priv/repository/pypi-public/simple/
PIP_TRUSTED_HOST=nexus3-cdp.apps.dxccdp-svil.ocp.mase.priv

# Security (mase-utils-secu): AUTH_ENABLED=true abilita middleware JWT + FGP + IAM (servono anche JWT_URI e MASE_API_*).
# AUTH_ENABLED=false o assente = nessuna auth, tutte le route accessibili.
AUTH_ENABLED=false
JWT_URI=https://sim-dev.mase.gov.it/core/api/iam/protocol/openid-connect/certs
# Con JWKS_INDEX=1 la verifica della firma JWT va a buon fine; senza (o =0) si riceve "Signature verification failed" (token sim-dev usa la seconda chiave nel JWKS).
JWKS_INDEX=1
# Chiave pubblica ECDSA e props IAM (verifica FGP, refresh token)
MASE_API_AUTHENTICATION=https://sim-dev.mase.gov.it/core/api/authentication
MASE_API_IAM=http://iam.apps.psnleo01.ocp.mase.priv/iam
# Opzionali (default in mase-utils-secu)
# IAM_ALG=RS256
# OTP_SECRET: abilita auth M2M (header m2m-token). Se assente, M2M disabilitato.
# OTP_SECRET=
# Solo sviluppo: MASE_SECU_SSL_VERIFY=false disabilita verifica certificati (es. cert scaduto su JWT_URI)
MASE_SECU_SSL_VERIFY=false
# Per portale/sim-dev includere in CORS_ORIGINS: https://sim-dev.mase.gov.it

# -----------------------------------------------------------------------------
# Frontend (React + Vite + OpenLayers)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=5173
FRONTEND_DEBUG_PORT=9229
# Debug: attach IDE al frontend (porta 9229). Per disattivare: commenta NODE_OPTIONS.
NODE_OPTIONS=--inspect

# Utenza mockata in standalone (opzionale). Solo sviluppo/test senza shell.
# Valori di esempio da requestHeaders (Cookie + fgp).
VITE_MOCK_USER={"preferred_username":"utente16@mase","nome":"Giulio Cesare","cognome":"Di Giovambattista","email":"utente16@mase.com"}
